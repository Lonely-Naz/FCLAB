# Server
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
SYNC_SECRET=change-me

# Feishu open platform app
FEISHU_APP_ID=cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxx

# Option A: sync one or more Wiki nodes. The backend resolves node -> doc token.
FEISHU_WIKI_NODE_TOKENS=wikcnxxxxxxxxxxxx,wikcnyyyyyyyyyyyy

# Option B: sync a whole Wiki space tree. Optional root token limits traversal.
FEISHU_WIKI_SPACE_ID=xxxxxxxxxxxxxxxx
FEISHU_WIKI_ROOT_NODE_TOKEN=
FEISHU_WIKI_MAX_DEPTH=4

# Option C: sync direct docx document IDs.
FEISHU_DOCX_DOCUMENT_IDS=doxcnxxxxxxxxxxxx,doxcnyyyyyyyyyyyy

# Optional OpenAI-compatible chat completion endpoint.
# If omitted, /api/ask returns a local RAG summary from matched chunks.
MODEL_API_URL=
MODEL_API_KEY=
MODEL_NAME=gpt-4o-mini
